---
import { Image } from 'astro:assets';
import oliveSprig from '@/assets/images/olive-sprig-mark-v2.webp';
import type { Settings } from '@/lib/content';

interface Props {
  settings: Settings;
}

const baseURL = import.meta.env.BASE_URL;
const { settings } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const leftLinks = [
  { href: baseURL, label: 'Home' },
  { href: baseURL + '/about', label: 'About' }
];
const rightLinks = [
  { href: baseURL + '/menus', label: 'Menus' },
  { href: baseURL + '/extras', label: 'Extras' },
  { href: baseURL + '/contact', label: 'Contact' }
];
const isCurrent = (href: string) => href === '/' ? currentPath === '/' : currentPath === href;
---

<header class="site-header">
  <nav class="nav" aria-label="Main navigation">
    <div class="nav-group nav-group-left">
      {leftLinks.map((link) => (
        <a href={link.href} class="nav-link" aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
    </div>
    <a href={baseURL} class="brand" aria-label="La Table d'Amy home">
      <Image src={oliveSprig} alt="" width={54} layout="fixed" quality="high" class="sprig-mark brand-sprig" loading="eager"/>
      <span>{settings.business.name}</span>
      <small>Meal delivery in the Gers</small>
    </a>
    <div class="nav-group nav-group-right">
      {rightLinks.map((link) => (
        <a href={link.href} class="nav-link" aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
      <a href="#enquire" class="button button-small">Enquire</a>
    </div>
  </nav>
</header>
