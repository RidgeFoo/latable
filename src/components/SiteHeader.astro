---
const { settings } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const leftLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' }
];
const rightLinks = [
  { href: '/menus', label: 'Menus' },
  { href: '/extras', label: 'Extras' },
  { href: '/contact', label: 'Contact' }
];
const isCurrent = (href) => href === '/' ? currentPath === '/' : currentPath === href;
---

<header class="site-header">
  <nav class="nav" aria-label="Main navigation">
    <div class="nav-group nav-group-left">
      {leftLinks.map((link) => (
        <a href={link.href} class="nav-link" aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
    </div>
    <a href="/" class="brand" aria-label="La Table d'Amy home">
      <img class="sprig-mark brand-sprig" src="/images/olive-sprig-mark.webp" alt="" width="78" height="33" />
      <span>{settings.business.name}</span>
      <small>Meal delivery in the Gers</small>
    </a>
    <div class="nav-group nav-group-right">
      {rightLinks.map((link) => (
        <a href={link.href} class="nav-link" aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
      <a href="/contact" class="button button-small">Enquire</a>
    </div>
  </nav>
</header>
