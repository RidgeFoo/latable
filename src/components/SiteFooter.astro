---
import { Image } from 'astro:assets';
import footerBranch from '@/assets/images/olive-branch-ornament.webp';
import type { Settings } from '@/lib/content';

interface Props {
  settings: Settings;
}

const { settings } = Astro.props;
---

<footer class="site-footer">
  <Image src={footerBranch} alt="" width={72} layout="fixed" quality="high" class="footer-ornament" />
  <nav aria-label="Footer navigation">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/menus">Menus</a>
    <a href="/extras">Extras</a>
    <a href="/contact">Contact</a>
  </nav>
  <p>© 2026 {settings.business.name} | Meal delivery in the Gers</p>
</footer>
