---
import { Image } from 'astro:assets';
import amyPortrait from '@/assets/images/amy-portrait-engraving-ink.webp';
import bookendSprig from '@/assets/images/bookend-sprig.webp';
import celebrationCake from '@/assets/images/celebration-cake-engraving-ink.webp';
import contactTableDetail from '@/assets/images/contact-table-detail-ink.webp';
import formOliveBranch from '@/assets/images/form-olive-branch.webp';
import fridgeStock from '@/assets/images/fridge-stock-engraving-ink.webp';
import gersCountryside from '@/assets/images/hero-gers-countryside-ink.webp';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import MenuCard from '@/components/MenuCard.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import { getExtras, getMenusWithDesserts, getSettings } from '@/lib/content';

const settings = getSettings();
const menus = getMenusWithDesserts().filter((menu) => menu.featured);
const extras = getExtras().filter((extra) => extra.featured);
---

<BaseLayout title={`${settings.business.name} | Meal delivery in the Gers`} description={settings.business.tagline}>
  <main class="page-shell">
    <SiteHeader settings={settings} />

    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <h1 id="hero-title">Home-cooked meals delivered to your gîte in the Gers</h1>
        <p>Relax and enjoy your stay. Amy prepares and delivers delicious, seasonal meals straight to your door.</p>
        <p class="bookended-action">
          <a class="button" href="/menus">View Menus</a>
          <Image src={bookendSprig} alt="" width={37} layout="fixed" quality="high" class="action-sprig" loading="eager"/>
        </p>
      </div>
      <Image class="hero-image print-art" src={gersCountryside} alt="Sepia engraving of a farmhouse in the Gers countryside" width={1200} layout="constrained" quality="high" priority />
    </section>

    <section class="about-band">
      <Image class="portrait print-art" src={amyPortrait} alt="Sepia engraving portrait of Amy" width={190} layout="fixed" quality="high" loading="eager"/>
      <div>
        <SectionTitle variant="inline" imgLoading='eager'>About Amy</SectionTitle>
        <p>I love to cook nourishing, flavourful food using the best local ingredients. Whether you are here for a weekend escape or a longer holiday, I will take care of the cooking so you can focus on making memories.</p>
        <p>All meals are home-cooked, delivered ready to heat and enjoy.</p>
      </div>
    </section>

    <section class="section">
      <SectionTitle>Our Menus</SectionTitle>
      <div class="menu-grid">
        {menus.map((menu) => <MenuCard menu={menu} priceLabel={settings.pricing.menuPriceLabel} />)}
      </div>
      <p class="centered bookended-action">
        <Image src={bookendSprig} alt="" width={37} layout="fixed" quality="high" class="action-sprig action-sprig-left" />
        <a class="button" href="/menus">View Full Menus</a>
        <Image src={bookendSprig} alt="" width={37} layout="fixed" quality="high" class="action-sprig" />
      </p>
    </section>

    <section class="extras-preview" aria-label="Extras preview">
      {extras.map((extra) => (
        <article>
          <Image class="extra-art print-art" src={extra.slug === 'fridge-stock' ? fridgeStock : celebrationCake} alt="" width={140} layout="fixed" quality="high" />
          <div>
            <h2>{extra.title}</h2>
            <p>{extra.summary}</p>
            <a href="/extras" class="button">Learn more</a>
          </div>
        </article>
      ))}
    </section>

    <section class="section">
      <SectionTitle>How It Works</SectionTitle>
      <div class="steps">
        <article>
          <span>1</span>
          <h3>Choose</h3>
          <p>Browse the menus and extras and let Amy know what you need.</p>
        </article>
        <article>
          <span>2</span>
          <h3>Amy cooks & delivers</h3>
          <p>Everything is prepared with care and delivered to your gîte.</p>
        </article>
        <article>
          <span>3</span>
          <h3>You enjoy</h3>
          <p>Heat, serve and enjoy delicious home-cooked food.</p>
        </article>
      </div>
    </section>

    <section class="contact-band">
      <Image class="contact-landscape print-art" src={contactTableDetail} alt="" width={564} layout="constrained" quality="high" />
      <div class="contact-panel" id="enquire">
        <aside class="contact-card">
          <SectionTitle>Enquire</SectionTitle>
          <p>Amy would love to help make your stay even more memorable.</p>
          <p><a href={`tel:${settings.contact.phone}`}>{settings.contact.phone}</a></p>
          <p><a href={`mailto:${settings.contact.email}`}>{settings.contact.email}</a></p>
          <p>{settings.business.area}</p>
        </aside>
        <form class="enquiry-form" action={`mailto:${settings.contact.email}`} method="post" enctype="text/plain">
          <label>
            <span>Your name</span>
            <input name="name" autocomplete="name" placeholder="Your name" />
          </label>
          <label>
            <span>Email address</span>
            <input name="email" type="email" autocomplete="email" placeholder="Email address" />
          </label>
          <label>
            <span>Preferred date</span>
            <input name="date" type="date" />
          </label>
          <label>
            <span>Number of guests</span>
            <input name="guests" type="number" min="1" placeholder="Number of guests" />
          </label>
          <label class="full">
            <span>Tell Amy about your stay</span>
            <textarea name="message" rows="4" placeholder="Tell Amy about your stay..."></textarea>
          </label>
          <button class="button" type="submit">Send Enquiry</button>
        </form>
      </div>
      <Image class="contact-branch print-art" src={formOliveBranch} alt="" width={170} layout="fixed" quality="high" />
    </section>

    <SiteFooter settings={settings} />
  </main>
</BaseLayout>
