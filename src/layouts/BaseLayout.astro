---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "La Table d'Amy",
  description = "Home-cooked meals delivered to your gîte in the Gers"
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
